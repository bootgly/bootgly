# Ignore IDEs folders...
.idea/
# Ignore files by extension...
*.iso
*.log
*.md
*.sh
# Ignore locks, bin, envs...
composer
composer.lock


### @Bootgly ###

## Global folders
# Excluded
**/&
# Versus
**/vs
# Metafolder (@)
@/*
# Additional folders
!@/phpstan/
# Adittional files
!@/phpstan.neon
!README.md
!CHANGELOG.md

## Private files
# Benchmarks
_*.benchmark.php
# Examples
_*.example.php
# Tests
_*.test.php


#-- /Classes --#
# ...

#-- /resources --#
/vendor/
/tmp/

#- /configs
# Config environment files (secrets)
configs/**/.env
configs/**/.env.*
projects/configs/**/.env
projects/configs/**/.env.*
projects/**/configs/**/.env
projects/**/configs/**/.env.*

#- /public
/public/*

# /scripts
# Ignore private scripts
/scripts/_*.php

#- /workdata
# Ignore all files here
/workdata/*.*
