{
   "name": "bootgly/bootgly",
   "version": "0.24.0-beta",
   "type": "library",
   "description": "The Bootgly PHP Framework.",
   "license": "MIT",
   "keywords": [
      "bootgly",
      "php",
      "framework",

      "bootable"
   ],
   "authors": [
      {
         "name": "Rodrigo Vieira",
         "email": "rodrigo@bootgly.com",
         "homepage": "https://www.bootgly.com/"
      }
   ],

   "autoload": {
      "files": [
         "./autoboot.php"
      ]
   },

   "require": {
      "php": "^8.4",
      "ext-openssl": "*"
   },
   "suggest": {
      "ext-pcntl": "Required by the Console platform on Linux (workers, forks and signals)",
      "ext-posix": "Required by the Console platform on Linux (process control and privileges)",
      "ext-sqlite3": "Required by the SQLite database driver (ADI/Databases/SQL/Drivers/SQLite)"
   },
   "autoload-dev": {
      "psr-4": {
         "Bootgly\\PHPStan\\": "@/phpstan/"
      }
   },

   "require-dev": {
      "phpstan/phpstan": "2.1.40"
   }
}
