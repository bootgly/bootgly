{
  "info": {
    "_postman_id": "7a8d0551-7f5b-4d76-9a3f-e4f7cccb6a4d",
    "name": "Bootgly Demo HTTP_Server_CLI - Native Async PostgreSQL",
    "description": "Postman collection for the Bootgly Demo HTTP_Server_CLI native async PostgreSQL and ORM Data Mapper handler.\n\nBefore running:\n1. In projects/Demo-HTTP_Server_CLI/Demo-HTTP_Server_CLI.project.php, enable the response-database handler.\n2. Configure DB_HOST, DB_PORT, DB_NAME, DB_USER, DB_PASS as needed. DB_ENABLED defaults to true for this demo.\n3. Start the Demo HTTP server.\n4. Run requests in order, starting with Setup demo tables.\n\nDefault base_url: http://127.0.0.1:8082",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8082",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "00 - Index",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": "{{base_url}}/",
        "description": "Lists the database demo routes exposed by HTTP_Server_CLI-response-database.SAPI.php."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('HTTP 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('JSON body', function () {",
              "  pm.response.to.have.jsonBody();",
              "});",
              "const json = pm.response.json();",
              "pm.test('status ok', function () {",
              "  pm.expect(json.status).to.eql('ok');",
              "});",
              "pm.test('routes available', function () {",
              "  pm.expect(json.routes).to.include('/deferred/database/setup');",
              "  pm.expect(json.routes).to.include('/deferred/database/orm/users');",
              "  pm.expect(json.routes).to.include('/deferred/database/orm/lazy-relations');",
              "});"
            ]
          }
        }
      ]
    },
